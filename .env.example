# 火山方舟 API 配置
# 生成模型 API Key（必填）
ARK_API_KEY_GENERATOR=your_api_key_here
# 验证模型 API Key（可选，不填则与生成模型共用相同的 API Key）
# ARK_API_KEY_VERIFIER=your_api_key_here
# 兼容旧版配置（可选，优先使用 ARK_API_KEY_GENERATOR）
# ARK_API_KEY=your_api_key_here

# 模型名称配置
# 生成模型名称（可选，默认：doubao-seed-1-6-flash-250828）
# MODEL_NAME_GENERATOR=doubao-seed-1-6-flash-250828
# 验证模型名称（可选，不填则与生成模型使用相同模型）
# MODEL_NAME_VERIFIER=doubao-seed-1-6-flash-250828

# API 基础 URL
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 应用配置
LOG_LEVEL=DEBUG
CACHE_FILE=cache.json

# 双模型验证配置
ENABLE_DUAL_MODEL_VERIFICATION=true
MAX_VERIFICATION_RETRIES=2
