# 火山方舟 / OpenAI 兼容 API 配置
# ==================================================
# 用 base_url 切换服务商：
#   - 火山方舟（豆包 + 第三方模型接入点）：https://ark.cn-beijing.volces.com/api/v3
#   - DeepSeek 官方：https://api.deepseek.com
# ==================================================

# 必填：API Key
ARK_API_KEY_GENERATOR=your_api_key_here

# 必填：模型名称
# - 豆包：doubao-seed-1-6-flash-250828、doubao-seed-2-0-lite-260215
# - DeepSeek 火山接入点：ep-20240101xxxxxxxx-xxxxx
# - DeepSeek 官方：deepseek-chat、deepseek-reasoner
MODEL_NAME_GENERATOR=doubao-seed-1-6-flash-250828

# 可选：API 基础 URL（OpenAI 兼容协议）
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 可选：日志级别
LOG_LEVEL=DEBUG

# 可选：服务监听端口（默认 8086）
SERVER_PORT=8086

# 可选：是否开启深度思考（默认 true）
ENABLE_THINKING=true

# 可选：思考等级 low / medium / high（默认 high）
THINKING_EFFORT=high
